; Kernel
; Timer address = 0x52D00

@data
!timer_start dq #0x52D00

@text
.LDI $0 !timer_start
.LDQ $0 $0          ; $0 = 0x52D00, actual timer MMIO address

.LDQ $1 $0          ; $1 = start time

:wait
.LDQ $2 $0          ; $2 = current time
.SUB $3 $2 $1       ; $3 = elapsed
.LDI $4 #1000
.JGE :done $3 $4

.JMP :wait

:done
.LDI $0 #0
.HLT