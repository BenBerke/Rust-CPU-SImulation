; 512 should be 0x44
; 513 should be 0xBB
; Otherwise kernel is missing

.LDI $0 #0x600D
.HLT

.LDM $2 %512 ; Loads 512 and 513
.LDI $3 #0xBB44 ; Expected kernel signature
.SUB $2 $2 $3

.JZF :check $2
.LDI $0 #0xDEAD
.HLT

:check        ; Kernel exists
.JAB %514     ; Kernel starts here
.HLT           ; Fail safe