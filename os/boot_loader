; 512 should be 0x44
; 513 should be 0xBB
; Otherwise kernel is missing

; Load kernel from disk to memory and boot it
; Kernel count is at 514 and 515


; === Load Sector 1 to RAM ===
.LDI $1 #1
.DTM %512 %1 $1 ; Pull Sector 1 from disk into RAM addresses 512-1024

; === Validate Kernel ===
.LDM $1 %512
.LDI $2 #0xBB44
.SUB $1 $1 $2
.JZF :boot_kernel $1
.LDI $0 #0xDEAD
.HLT

:boot_kernel
.LDM $1 %514 ; Sector Count
.DTM %512 %1 $1 ; Reload the full kernel
.JAB %516
.LDI $0 #15
.HLT